{
    "compilerOptions": {
        "outDir": "./dist",
        "allowImportingTsExtensions": true,
        "rootDir": "./src",
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "moduleResolution": "NodeNext",
        "module": "NodeNext",
        "strict": false,
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true,
        "noEmit": true,
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}